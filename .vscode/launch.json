{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Sheriff - Flutter Web (Chrome)",
      "request": "launch",
      "type": "dart",
      "program": "sheriff_game/lib/main.dart",
      "cwd": "${workspaceFolder}/sheriff_game",
      "args": ["-d", "chrome", "--web-port", "3000"]
    },
    {
      "name": "Sheriff - Chrome (built app)",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}/sheriff_game"
    }
  ],
  "compounds": []
}
