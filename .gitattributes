# Normalize line endings: store text as LF in the repo, check out native.
# Keeps the cross-platform Dart/Flutter project consistent across machines/AIs.
* text=auto

# Treat common binary assets as binary (never munge line endings).
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.gif  binary
*.ttf  binary
*.otf  binary
*.woff  binary
*.woff2 binary
*.wasm binary
